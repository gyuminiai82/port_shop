generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MIN_SHOP_USER {
  id         String   @id @default(uuid()) // SSO User ID와 매핑
  email      String   @unique
  name       String?
  tier       String   @default("BRONZE")
  points     Int      @default(0)
  totalSpent Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MIN_CATEGORY {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   MIN_CATEGORY?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children MIN_CATEGORY[] @relation("CategoryHierarchy")
  products MIN_PRODUCT[]
}

model MIN_PRODUCT {
  id          String   @id @default(uuid())
  categoryId  String?
  name        String
  description String?  @db.Text
  price       Int
  stock       Int      @default(0)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   MIN_CATEGORY?        @relation(fields: [categoryId], references: [id])
  images     MIN_PRODUCT_IMAGE[]
  options    MIN_PRODUCT_OPTION[]
  reviews    MIN_REVIEW[]
  cartItems  MIN_CART_ITEM[]
  orderItems MIN_ORDER_ITEM[]
  wishlists  MIN_WISHLIST_ITEM[]
}

model MIN_PRODUCT_IMAGE {
  id        String   @id @default(uuid())
  productId String
  url       String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  product MIN_PRODUCT @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model MIN_PRODUCT_OPTION {
  id        String   @id @default(uuid())
  productId String
  name      String // 예: "색상", "사이즈"
  value     String // 예: "레드", "XL"
  addPrice  Int      @default(0) // 옵션 추가금
  stock     Int      @default(0) // 옵션별 재고
  createdAt DateTime @default(now())

  product    MIN_PRODUCT      @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  MIN_CART_ITEM[]
  orderItems MIN_ORDER_ITEM[]
}

model MIN_REVIEW {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int      @default(5)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product MIN_PRODUCT @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model MIN_WISHLIST {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MIN_WISHLIST_ITEM[]
}

model MIN_WISHLIST_ITEM {
  id         String   @id @default(uuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())

  wishlist MIN_WISHLIST @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  MIN_PRODUCT  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
}

model MIN_CART {
  id        String          @id @default(uuid())
  userId    String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     MIN_CART_ITEM[]
}

model MIN_CART_ITEM {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  optionId  String? // 선택된 옵션
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    MIN_CART            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product MIN_PRODUCT         @relation(fields: [productId], references: [id], onDelete: Cascade)
  option  MIN_PRODUCT_OPTION? @relation(fields: [optionId], references: [id])

  @@unique([cartId, productId, optionId])
}

model MIN_ORDER {
  id          String   @id @default(uuid())
  userId      String
  totalAmount Int
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED 등
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    MIN_ORDER_ITEM[]
  payment  MIN_PAYMENT?
  delivery MIN_DELIVERY?
}

model MIN_ORDER_ITEM {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  optionId  String?
  quantity  Int
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   MIN_ORDER           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product MIN_PRODUCT         @relation(fields: [productId], references: [id])
  option  MIN_PRODUCT_OPTION? @relation(fields: [optionId], references: [id])
}

model MIN_PAYMENT {
  id            String    @id @default(uuid())
  orderId       String    @unique
  method        String // CARD, TOSS, VIRTUAL_ACCOUNT 등
  amount        Int
  transactionId String? // PG사 고유 거래 번호
  status        String    @default("COMPLETED") // COMPLETED, FAILED, REFUNDED
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  order MIN_ORDER @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model MIN_DELIVERY {
  id          String    @id @default(uuid())
  orderId     String    @unique
  recipient   String
  address     String
  trackingNo  String?
  status      String    @default("PREPARING") // PREPARING, SHIPPING, DELIVERED
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order MIN_ORDER @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model MIN_COUPON {
  id           String   @id @default(uuid())
  name         String
  discountRate Int      @default(0) // 퍼센트 할인
  discountAmt  Int      @default(0) // 정액 할인
  minOrderAmt  Int      @default(0) // 최소 주문 금액
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  userCoupons MIN_USER_COUPON[]
}

model MIN_USER_COUPON {
  id        String    @id @default(uuid())
  userId    String
  couponId  String
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  coupon MIN_COUPON @relation(fields: [couponId], references: [id])
}

model MIN_SHOP_ADMIN {
  id        String   @id @default(uuid()) /// 관리자 고유 ID
  email     String   @unique /// 관리자 이메일(로그인)
  password  String /// 비밀번호
  name      String /// 관리자 이름
  role      String   @default("ADMIN") /// 권한
  createdAt DateTime @default(now()) /// 계정 생성일시
  updatedAt DateTime @updatedAt /// 계정 수정일시
}
